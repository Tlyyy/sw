{
  "name": "project-ledger",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "data:generate": "node scripts/generate-catalog.mjs",
    "data:check": "node scripts/generate-catalog.mjs --check",
    "build": "npm run data:check && vue-tsc -b && vite build && node scripts/check-build.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:core": "playwright test e2e/app.spec.ts e2e/regressions.spec.ts e2e/mobile-ux.spec.ts e2e/sync.spec.ts",
    "test:e2e:ocr": "playwright test e2e/gem-market-ocr.spec.ts --project=desktop",
    "test:e2e:ci": "playwright test e2e/app.spec.ts e2e/regressions.spec.ts e2e/mobile-ux.spec.ts e2e/sync.spec.ts e2e/gem-market-ocr.spec.ts"
  },
  "dependencies": {
    "@instantdb/core": "^1.0.49",
    "chart.js": "^4.5.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@types/node": "^24.0.7",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
